.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.logo {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 50rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.description {
  font-size: 28rpx;
  color: #888;
  text-align: center;
  margin-bottom: 80rpx;
  padding: 0 60rpx;
}

.auth-button {
  width: 80%;
  background-color: #07c160;
  color: #fff;
  border-radius: 999rpx;
  margin-bottom: 20rpx; /* Add some space below the auth button */
}

.cancel-button {
  width: 80%;
  background-color: #f0f0f0;
  color: #333;
  border-radius: 999rpx;
}

.tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 40rpx;
}