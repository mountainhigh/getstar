<view class="container">
  <!-- 未创建家庭 -->
  <view class="no-family" wx:if="{{!hasFamily}}">
    <view class="welcome-card card">
      <text class="welcome-icon">👋</text>
      <text class="welcome-title">欢迎来到 攒星星</text>
      <text class="welcome-desc">创建家庭账户，开启孩子的习惯养成之旅</text>
      <button class="btn btn-primary mt-30" bindtap="createFamily">创建家庭</button>
    </view>

    <!-- 设置入口 -->
    <view class="settings-section">
      <view class="settings-item" bindtap="initDatabase">
        <text class="settings-icon">🔄</text>
        <text class="settings-text">初始化数据库</text>
        <text class="settings-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 已创建家庭 -->
  <view wx:else>
    <!-- 家庭信息卡片 -->
    <view class="family-info card">
      <view class="family-header">
        <text class="family-title">我的家庭</text>
        <text class="family-members">{{childrenList.length}} 个孩子</text>
      </view>
    </view>

    <!-- 孩子列表 -->
    <view class="children-section" wx:if="{{childrenList.length > 0}}">
      <view class="section-header">
        <text class="section-title">孩子列表</text>
        <button class="btn-add-child" wx:if="{{childrenList.length < 5}}" bindtap="addChild">
          <text>+</text>
          <text>添加</text>
        </button>
      </view>

      <view class="children-list">
        <view
          class="child-item card {{item._id === currentChildId ? 'active' : ''}}"
          wx:for="{{childrenList}}"
          wx:key="_id">
          <view class="child-avatar" bindtap="editChild" data-id="{{item._id}}">
            <image wx:if="{{item.avatarType === 'image' || (item.avatar && item.avatar.length > 4)}}" src="{{item.avatar}}" mode="aspectFill" class="avatar-image"></image>
            <text wx:else class="avatar-emoji-display">{{item.avatar || '👶'}}</text>
            <view class="avatar-edit">
              <text>编辑</text>
            </view>
          </view>
          <view class="child-info">
            <view class="child-header">
              <text class="child-name">{{item.name}}</text>
              <text class="child-level">Lv.{{item.level}}</text>
            </view>
            <view class="child-stats">
              <view class="stat-item">
                <text class="stat-value">{{item.points}}</text>
                <text class="stat-label">星星</text>
              </view>
              <view class="stat-divider"></view>
              <view class="stat-item">
                <text class="stat-value coins">🪙</text>
                <text class="stat-value">{{item.coins}}</text>
                <text class="stat-label">金币</text>
              </view>
            </view>
          </view>
          <view class="child-actions" wx:if="{{childrenList.length > 1}}">
            <view class="action-buttons">
              <!-- 未选中时显示切换按钮 -->
              <view class="btn-switch-icon" wx:if="{{item._id !== currentChildId}}" bindtap="switchChild" data-id="{{item._id}}">
                <text class="switch-icon">→</text>
              </view>
              <!-- 删除按钮 -->
              <view class="btn-delete-icon" bindtap="deleteChild" data-id="{{item._id}}">
                <text class="delete-icon">−</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{childrenList.length === 0}}">
      <text class="empty-icon">👶</text>
      <text class="empty-text">还没有添加孩子</text>
      <button class="btn btn-primary mt-30" bindtap="addChild">添加孩子</button>
    </view>

    <!-- 设置入口 -->
    <view class="settings-section">
      <view class="settings-item" bindtap="showHelp">
        <text class="settings-icon">❓</text>
        <text class="settings-text">使用帮助</text>
        <text class="settings-arrow">›</text>
      </view>
      <view class="settings-item" bindtap="showAbout">
        <text class="settings-icon">ℹ️</text>
        <text class="settings-text">关于我们</text>
        <text class="settings-arrow">›</text>
      </view>
      <!-- 修复数据      -->
      <view class="settings-item" bindtap="fixData">
        <text class="settings-icon">🔧</text>
        <text class="settings-text">修复数据</text>
        <text class="settings-arrow">›</text>
      </view>

    </view>
  </view>
</view>

<!-- 添加/编辑孩子弹窗 -->
<view class="modal" wx:if="{{showChildModal}}" catchtap="closeChildModal">
  <view class="modal-content child-modal" catchtap="stopPropagation">
    <view class="modal-title">{{isEdit ? '编辑孩子' : '添加孩子'}}</view>
    
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input 
        class="form-input" 
        placeholder="请输入孩子姓名"
        value="{{childForm.name}}"
        bindinput="onNameInput"
        maxlength="10"
      />
    </view>
    
    <view class="avatar-choose">
      <text class="form-label">选择头像</text>
      <view class="avatar-list">
        <view
          class="avatar-option {{item.value === childForm.avatar ? 'active' : ''}}"
          wx:for="{{avatarList}}"
          wx:for-index="index"
          wx:key="index"
          bindtap="selectAvatar"
          data-avatar="{{item.value}}"
          data-type="{{item.type}}">
          <image wx:if="{{item.type === 'image'}}" src="{{item.value}}" class="avatar-img-small"></image>
          <text wx:else class="avatar-emoji">{{item.value}}</text>
        </view>
        
        <!-- 自定义上传按钮 -->
        <view class="avatar-option upload-btn {{childForm.avatarType === 'image' && (childForm.avatar.startsWith('http') || childForm.avatar.startsWith('wxfile')) ? 'active' : ''}}" bindtap="chooseImage">
          <text class="upload-icon">📷</text>
        </view>
      </view>
      
      <!-- 当前选中预览（如果是自定义上传的） -->
      <view class="avatar-preview" wx:if="{{childForm.avatarType === 'image'}}">
        <text class="preview-label">当前预览:</text>
        <image src="{{childForm.avatar}}" mode="aspectFill" class="preview-image"></image>
      </view>
    </view>
    
    <view class="modal-actions">
      <button class="btn btn-outline" bindtap="closeChildModal">取消</button>
      <button class="btn btn-primary" bindtap="saveChild">保存</button>
    </view>
  </view>
</view>
