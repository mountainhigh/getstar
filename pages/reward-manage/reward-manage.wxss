/* 礼物管理页面样式 - 珊瑚红/青绿色主题 */
.reward-manage {
  min-height: 100vh;
  background: #f8f9fa;
  padding-bottom: 40rpx;
}

/* 页面头部 */
.header-section {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  padding: 60rpx 30rpx 40rpx;
  border-radius: 0 0 40rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 107, 107, 0.3);
}

.header-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-info {
  flex: 1;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.btn-add {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 72rpx;
  padding: 0 32rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 36rpx;
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.btn-add::after {
  border: none;
}

.btn-icon {
  font-size: 32rpx;
  font-weight: 700;
}

/* 礼物列表 */
.reward-list {
  padding: 24rpx;
}

.reward-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.reward-item:active {
  transform: scale(0.98);
}

.reward-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.reward-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.icon-text {
  color: #fff;
  font-size: 40rpx;
  font-weight: bold;
}

.reward-info {
  flex: 1;
  min-width: 0;
}

.reward-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reward-meta {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.reward-category {
  font-size: 24rpx;
  color: #95A5A6;
  padding: 4rpx 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.reward-cost {
  display: flex;
  align-items: center;
}

.cost-icon {
  color: #FFB800;
  font-size: 22rpx;
  margin-right: 4rpx;
}

.cost-value {
  color: #FF6B6B;
  font-size: 26rpx;
  font-weight: 700;
}

.reward-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
}

.btn-action {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border: none;
  transition: all 0.3s ease;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 80rpx !important;
  min-width: 80rpx !important;
  min-height: 80rpx !important;
  box-sizing: border-box !important;
}

.btn-action::after {
  border: none;
}

.btn-action:active {
  transform: scale(0.9);
}

.btn-edit {
  background: #E8F4FD;
  color: #45B7D1;
}

.btn-delete {
  background: #FFEEF0;
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-bg {
  width: 180rpx;
  height: 180rpx;
  background: linear-gradient(135deg, #FFE5E5 0%, #FFF0E5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.empty-icon {
  font-size: 90rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #95A5A6;
  margin-bottom: 48rpx;
}

.btn-empty-add {
  padding: 28rpx 56rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 107, 107, 0.3);
}

.btn-empty-add::after {
  border: none;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FFE5E5;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #95A5A6;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 24rpx;
  right: 24rpx;
  width: calc(100% - 48rpx);
  box-sizing: border-box;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  overflow: visible;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  padding: 0 24rpx;
}

.modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.modal-close {
  font-size: 36rpx;
  color: #95A5A6;
  padding: 10rpx;
}

.modal-body {
  flex: 1;
  padding: 24rpx 24rpx;
  overflow-y: auto;
  max-height: calc(90vh - 160rpx);
  box-sizing: border-box;
  width: 100%;
}

/* 隐藏滚动条 */
.modal-body::-webkit-scrollbar {
  display: none;
}

.modal-body {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.modal-content::-webkit-scrollbar {
  display: none;
}

.modal-content {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx 40rpx;
  border-top: 2rpx solid #f0f0f0;
  width: 100%;
  box-sizing: border-box;
}

/* 表单 */
.form-group {
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f9fa;
  border-radius: 14rpx;
  padding: 0 16rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  box-sizing: border-box;
  max-width: 100%;
}

.form-input:focus {
  border-color: #FF6B6B;
  background: #fff;
}

/* 金币输入 */
.points-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.btn-minus,
.btn-plus {
  width: 72rpx !important;
  height: 72rpx !important;
  border-radius: 50%;
  background: #f8f9fa;
  border: 2rpx solid #E8ECEF;
  font-size: 36rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 72rpx !important;
  min-width: 72rpx !important;
  min-height: 72rpx !important;
  box-sizing: border-box !important;
}

.btn-minus::after,
.btn-plus::after {
  border: none;
}

.btn-minus {
  color: #FF6B6B;
}

.btn-plus {
  color: #4ECDC4;
}

.points-input {
  flex: 1;
  height: 72rpx;
  background: #f8f9fa;
  border-radius: 14rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #FF6B6B;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  max-width: calc(100% - 168rpx);
}

.points-input:focus {
  border-color: #FF6B6B;
  background: #fff;
}

/* 分类网格 */
.category-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.category-option {
  padding: 16rpx;
  background: linear-gradient(135deg, #f8f9fa 0%, #e8ecef 100%);
  border-radius: 14rpx;
  text-align: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  width: 100%;
  position: relative;
  cursor: pointer;
}

.category-option:active {
  transform: scale(0.95);
}

.category-option.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.4);
  transform: scale(1.02);
}

.category-option text {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.05);
}

.category-option.active text {
  color: #fff;
  font-weight: 600;
  text-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.2);
}

/* 图标网格 */
.icon-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 4rpx;
}

.icon-option {
  aspect-ratio: 1;
  background: linear-gradient(135deg, #f8f9fa 0%, #e8ecef 100%);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  box-sizing: border-box;
  width: 100%;
  position: relative;
  cursor: pointer;
}

.icon-option:active {
  transform: scale(0.95);
}

.icon-option.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-color: transparent;
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.4);
  transform: scale(1.02);
}

.icon-option text {
  font-size: 32rpx;
  color: #636E72;
  display: block;
  line-height: 1;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.05);
}

.icon-option.active text {
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.icon-option.active text {
  color: #fff;
}

/* 颜色网格 */
.color-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 6rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 0 4rpx;
}

.color-option {
  aspect-ratio: 1;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  border: 3rpx solid transparent;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  width: 100%;
  position: relative;
  cursor: pointer;
}

.color-option:active {
  transform: scale(0.95);
}

.color-option.active {
  border-color: #2D3436;
  transform: scale(1.02);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
}

.check-mark {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.3);
  line-height: 1;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 30rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.form-textarea:focus {
  border-color: #FF6B6B;
  background: #fff;
}

/* 按钮 */
.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.btn::after {
  border: none;
}

.btn-cancel {
  background: #f0f0f0;
  color: #636E72;
}

.btn-save {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 107, 0.3);
}

.btn-save:active {
  transform: scale(0.98);
}
