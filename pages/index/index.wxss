/* 欢迎区域 */
.welcome-section {
  padding: 40rpx;
  display: flex;
  justify-content: center;
}

.welcome-card {
  padding: 60rpx 40rpx;
  text-align: center;
}

.welcome-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.welcome-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.welcome-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  margin-bottom: 40rpx;
}

/* 孩子切换器 */
.child-switcher {
  margin-bottom: 30rpx;
}

.child-scroll {
  white-space: nowrap;
}

.child-item {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFF0F0 100%);
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  margin-right: 20rpx;
  border: 3rpx solid rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.child-item.active {
  border-color: #FF6B6B;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

.child-item.active .child-name {
  color: #FFFFFF;
}

.child-item.active .child-points {
  color: rgba(255, 255, 255, 0.9);
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.child-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 36rpx;
  line-height: 1;
}

.child-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.child-name {
  font-size: 15px;
  font-weight: 600;
  color: #2D3436;
}

.child-points {
  font-size: 12px;
  color: #FF6B6B;
  margin-top: 4rpx;
}

/* 星星卡片 */
.points-card {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  position: relative;
  overflow: hidden;
}

.points-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

.points-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  gap: 40rpx;
}

.points-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 50%;
}

.points-title {
  display: flex;
  flex-direction: row;
  align-items: baseline;
  gap: 12rpx;
}

.points-label {
  font-size: 14px;
  opacity: 0.9;
  font-weight: 500;
  letter-spacing: 1rpx;
}

.points-value {
  font-size: 52px;
  font-weight: 800;
  line-height: 1;
  text-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  letter-spacing: -2rpx;
}

.level-badge {
  background: rgba(255, 255, 255, 0.3);
  border-radius: 32rpx;
  padding: 14rpx 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.level-badge-icon {
  font-size: 24px;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.level-badge-text {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

.points-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  align-items: flex-end;
  width: 50%;
}

.coins-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 32rpx;
  padding: 14rpx 0;
  width: 100%;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.coins-icon {
  font-size: 24px;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.coins-value {
  font-size: 22px;
  font-weight: 800;
}

.coins-label {
  font-size: 13px;
  opacity: 0.95;
  font-weight: 500;
}

.exchange-btn {
  background: rgba(255, 255, 255, 0.98);
  color: #FF6B6B;
  border-radius: 32rpx;
  padding: 14rpx 0;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.2);
  transition: all 0.2s ease;
}

.exchange-btn:active {
  transform: scale(0.96);
  box-shadow: 0 3rpx 10rpx rgba(0, 0, 0, 0.15);
}

.exchange-icon {
  font-size: 24px;
}

.exchange-text {
  font-size: 16px;
  font-weight: 700;
  letter-spacing: 0.5rpx;
}

/* 等级进度 */
.level-info {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 22rpx 28rpx;
  backdrop-filter: blur(10rpx);
  position: relative;
  z-index: 1;
}

.level-bar-container {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.level-label {
  font-size: 15px;
  font-weight: 600;
  opacity: 0.95;
  white-space: nowrap;
  flex-shrink: 0;
  min-width: 150rpx;
  letter-spacing: 0.5rpx;
}

.level-bar {
  flex: 1;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 10rpx;
  overflow: hidden;
}

.level-progress {
  height: 100%;
  background: linear-gradient(90deg, #FFE66D 0%, #FFD93D 100%);
  border-radius: 10rpx;
  transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 0 12rpx rgba(255, 230, 109, 0.6);
}

.level-percent {
  font-size: 14px;
  font-weight: 700;
  opacity: 0.95;
  white-space: nowrap;
  min-width: 70rpx;
  text-align: right;
  letter-spacing: 0.5rpx;
}

/* 称号展示 */
.badge-display {
  margin-top: 24rpx;
  padding: 18rpx 28rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  position: relative;
  z-index: 1;
}

.badge-display:active {
  transform: scale(0.96);
  background: rgba(255, 255, 255, 0.35);
}

.badge-icon {
  font-size: 40rpx;
  filter: drop-shadow(0 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

.badge-name {
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

/* 习惯列表 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.section-title {
  font-size: 18px;
  font-weight: 600;
  color: #2D3436;
}

.section-subtitle {
  font-size: 14px;
  color: #95A5A6;
}

.habit-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.habit-item:active {
  transform: scale(0.98);
}

.habit-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.habit-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.habit-info {
  display: flex;
  flex-direction: column;
}

.habit-name {
  font-size: 16px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.habit-points {
  font-size: 14px;
  color: #FF6B6B;
  font-weight: 500;
}

.habit-right {
  flex-shrink: 0;
}

.check-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F8F9FA;
  border: 3rpx solid #E8ECEF;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.check-btn.checked {
  background: #4ECDC4;
  border-color: #4ECDC4;
}

.check-icon {
  font-size: 32px;
  font-weight: 700;
  color: #2D3436;
}

.check-btn.checked .check-icon {
  color: #FFFFFF;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80px;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 16px;
  color: #95A5A6;
}

/* 提示 */
.tips {
  display: flex;
  align-items: center;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-top: 30rpx;
}

.tips-icon {
  font-size: 20px;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 13px;
  color: #F39C12;
  flex: 1;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  width: 80%;
  text-align: center;
}

/* 打卡成功动画 */
.success-animation {
  margin-bottom: 30rpx;
}

.success-icon {
  font-size: 100px;
  display: inline-block;
  animation: bounce 0.6s ease;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.success-title {
  font-size: 24px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 20rpx;
}

.success-points {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  font-size: 18px;
  color: #FF6B6B;
  font-weight: 600;
}

.success-points .coins {
  color: #F39C12;
}

/* 升级动画 */
.level-up {
  background: linear-gradient(135deg, #FFE66D 0%, #FFD93D 100%);
}

.level-up-animation {
  margin-bottom: 30rpx;
}

.level-icon {
  font-size: 100px;
  display: inline-block;
  animation: spin 1s ease;
}

@keyframes spin {
  0% { transform: rotate(0deg) scale(1); }
  50% { transform: rotate(180deg) scale(1.3); }
  100% { transform: rotate(360deg) scale(1); }
}

.level-up-title {
  font-size: 24px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 20rpx;
}

.level-up-text {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  font-size: 18px;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.old-level {
  color: #95A5A6;
}

.new-level {
  color: #FF6B6B;
  font-weight: 700;
}

.arrow {
  color: #2D3436;
}

.level-up-name {
  font-size: 16px;
  color: #2D3436;
  margin-bottom: 30rpx;
}

/* 孩子弹窗 */
.child-modal {
  width: 85%;
  max-width: 600rpx;
  text-align: left;
}

.modal-title {
  font-size: 20px;
  font-weight: 700;
  color: #2D3436;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 表单项 */
.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background: #F8F9FA;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 16px;
  color: #2D3436;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  background: #FFFFFF;
  border-color: #FF6B6B;
}

/* 头像选择 */
.avatar-choose {
  margin-bottom: 40rpx;
}

.avatar-list {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.avatar-option {
  width: 100rpx;
  height: 100rpx;
  background: #F8F9FA;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.avatar-option.active {
  background: #FFF5F5;
  border-color: #FF6B6B;
}

.avatar-option:active {
  transform: scale(0.9);
}

.avatar-emoji {
  font-size: 48px;
}

/* 弹窗操作按钮 */
.modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-outline {
  flex: 1;
  background: #FFFFFF;
  color: #2D3436;
  border: 2rpx solid #E8ECEF;
}

.btn-outline:active {
  background: #F8F9FA;
}

