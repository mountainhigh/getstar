/* 主题色定义 */
:root {
  /* 主色调 - 温暖珊瑚橙 */
  --color-primary: #FF6B6B;
  --color-primary-light: #FF8E8E;
  --color-primary-dark: #FF5252;
  
  /* 辅助色 - 清新薄荷绿 */
  --color-secondary: #4ECDC4;
  --color-secondary-light: #7EDDD6;
  --color-secondary-dark: #3DBDB5;
  
  /* 强调色 - 明亮黄色 */
  --color-accent: #FFE66D;
  --color-accent-light: #FFF093;
  --color-accent-dark: #FFE03D;
  
  /* 背景色 */
  --color-bg-primary: #F7F9FC;
  --color-bg-secondary: #FFFFFF;
  --color-bg-accent: #FFF5F5;
  
  /* 文字色 */
  --color-text-primary: #2D3436;
  --color-text-secondary: #636E72;
  --color-text-muted: #95A5A6;
  --color-text-light: #B2BEC3;
  
  /* 边框色 */
  --color-border: #E8ECEF;
  --color-border-light: #F0F1F3;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
  --shadow-xl: 0 12rpx 40rpx rgba(0, 0, 0, 0.12);
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 20rpx;
  --radius-xl: 32rpx;
  --radius-full: 50%;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 24rpx;
  --spacing-lg: 32rpx;
  --spacing-xl: 48rpx;
}
