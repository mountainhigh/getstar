<view class="container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">习惯管理</text>
    <button class="btn-add" bindtap="goToTemplates">
      <text>+</text>
      <text>添加习惯</text>
    </button>
  </view>

  <!-- 习惯列表 -->
  <view class="habit-list">
    <view 
      class="habit-item card" 
      wx:for="{{habits}}" 
      wx:key="_id">
      <view class="habit-main">
        <view class="habit-icon" style="background: {{item.categoryColor}};">
          <text>{{item.icon}}</text>
        </view>
        <view class="habit-info">
          <text class="habit-name">{{item.name}}</text>
          <view class="habit-meta">
            <text class="habit-points">{{item.points}}积分</text>
            <text class="habit-category">{{item.category}}</text>
          </view>
        </view>
      </view>
      <view class="habit-actions">
        <button class="btn-action btn-up" bindtap="moveHabit" data-index="{{index}}" data-direction="up" wx:if="{{index > 0}}">
          <text>↑</text>
        </button>
        <button class="btn-action btn-down" bindtap="moveHabit" data-index="{{index}}" data-direction="down" wx:if="{{index < habits.length - 1}}">
          <text>↓</text>
        </button>
        <button class="btn-action btn-edit" bindtap="editHabit" data-id="{{item._id}}">
          <text>✎</text>
        </button>
        <button class="btn-action btn-delete" bindtap="deleteHabit" data-id="{{item._id}}">
          <text>✕</text>
        </button>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{habits.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">还没有习惯</text>
      <text class="empty-hint">点击"添加习惯"开始设置</text>
      <button class="btn btn-primary mt-30" bindtap="goToTemplates">添加习惯</button>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats card" wx:if="{{habits.length > 0}}">
    <text class="stats-title">习惯统计</text>
    <view class="stats-info">
      <text class="stats-count">{{habits.length}}</text>
      <text class="stats-label">个习惯</text>
    </view>
  </view>
</view>

<!-- 编辑习惯弹窗 -->
<view class="modal" wx:if="{{showEditModal}}" catchtap="closeEditModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-title">编辑习惯</view>
    
    <view class="form-item">
      <text class="form-label">习惯名称</text>
      <input 
        class="form-input" 
        placeholder="请输入习惯名称"
        value="{{editForm.name}}"
        bindinput="onNameInput"
        maxlength="20"
      />
    </view>
    
    <view class="form-item">
      <text class="form-label">积分</text>
      <view class="points-wrapper">
        <button class="btn-minus" bindtap="adjustPoints" data-delta="-1">-</button>
        <input 
          class="points-input" 
          type="number" 
          value="{{editForm.points}}"
          bindinput="onPointsInput"
        />
        <button class="btn-plus" bindtap="adjustPoints" data-delta="1">+</button>
      </view>
    </view>
    
    <view class="form-item">
      <text class="form-label">状态</text>
      <view class="switch-wrapper">
        <switch 
          checked="{{editForm.isActive}}" 
          bindchange="onActiveChange"
          color="#FF6B6B"
        />
        <text class="switch-label">{{editForm.isActive ? '激活' : '停用'}}</text>
      </view>
    </view>
    
    <view class="modal-actions">
      <button class="btn btn-outline" bindtap="closeEditModal">取消</button>
      <button class="btn btn-primary" bindtap="saveEdit">保存</button>
    </view>
  </view>
</view>
