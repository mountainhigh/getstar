<view class="welcome-page" wx:if="{{isLoading}}">
  <view class="welcome-content">
    <view class="app-logo">⭐</view>
    <view class="app-name">我要攒星星</view>
    <view class="app-slogan">让好习惯成为自然</view>
    
    <view class="loading-container" wx:if="{{!showError}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>

    <view class="error-container" wx:if="{{showError}}">
      <text class="error-text">加载失败，请检查网络</text>
      <button class="retry-btn" bindtap="retryInit">重试</button>
    </view>
  </view>
</view>

<view class="container" wx:if="{{!isLoading}}">
  <!-- 没有孩子时显示添加界面 -->
  <view class="welcome-section" wx:if="{{childrenList.length === 0}}">
    <view class="welcome-card card">
      <text class="welcome-icon">{{isNewUser ? '👋' : '👶'}}</text>
      <text class="welcome-title">{{isNewUser ? '欢迎使用 我要攒星星' : '添加孩子'}}</text>
      <text class="welcome-desc">{{isNewUser ? '添加孩子的信息,系统将自动为您添加10个精选习惯模板' : '还没有添加孩子,快来添加第一个孩子吧'}}</text>
      <button class="btn btn-primary mt-30" bindtap="addFirstChild">添加孩子</button>
    </view>
  </view>

  <!-- 孩子切换器 -->
  <view wx:else>
    <view class="child-switcher" wx:if="{{childrenList.length > 1}}">
    <scroll-view scroll-x class="child-scroll" show-scrollbar="{{false}}">
      <view class="child-item {{item._id === currentChildId ? 'active' : ''}}" 
            wx:for="{{childrenList}}" 
            wx:key="_id"
            bindtap="switchChild"
            data-id="{{item._id}}">
        <view class="child-avatar">
          <image wx:if="{{item.avatarType === 'image' || (item.avatar && item.avatar.length > 4)}}" src="{{item.avatar}}" mode="aspectFill" class="avatar-image"></image>
          <text wx:else class="avatar-emoji">{{item.avatar || '👶'}}</text>
        </view>
        <view class="child-info">
          <text class="child-name">{{item.name}}</text>
          <text class="child-points">{{item.points}}星星</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 星星卡片 -->
  <view class="points-card card" wx:if="{{currentChild}}">
    <view class="points-header">
      <view class="points-left">
        <view class="points-title">
          <text class="points-value">{{currentChild.points}}</text>
          <text class="points-label">星星</text>
        </view>
        <view class="level-badge">
          <text class="level-badge-icon">⭐</text>
          <text class="level-badge-text">Lv.{{currentChild.level}}</text>
        </view>
      </view>
      <view class="points-right">
        <view class="coins-row">
          <text class="coins-icon">🪙</text>
          <text class="coins-value">{{currentChild.coins}}</text>
          <text class="coins-label">金币</text>
        </view>
        <view class="exchange-btn" bindtap="goToExchange">
          <text class="exchange-icon">🎁</text>
          <text class="exchange-text">兑换礼物</text>
        </view>
      </view>
    </view>
    <view class="level-info">
      <view class="level-bar-container">
        <text class="level-label">{{levelName}}</text>
        <view class="level-bar">
          <view class="level-progress" style="width: {{levelProgress}}%"></view>
        </view>
        <text class="level-percent">{{levelProgress}}%</text>
      </view>
    </view>
    <!-- 称号展示 -->
    <view class="badge-display" wx:if="{{currentBadge}}" bindtap="goToBadges">
      <text class="badge-icon">{{currentBadge.icon}}</text>
      <text class="badge-name">{{currentBadge.name}}</text>
    </view>
  </view>

  <!-- 习惯列表 -->
  <view class="habit-list">
    <view class="section-header">
      <text class="section-title">今日习惯</text>
      <text class="section-subtitle">{{completedCount}}/{{habits.length}}</text>
    </view>
    
    <view class="habit-item card" 
          wx:for="{{habits}}" 
          wx:key="_id"
          bindtap="goToCheckIn"
          data-habit="{{item}}">
      <view class="habit-left">
        <view class="habit-icon" style="background: {{item.categoryColor}};">
          <text>{{item.icon}}</text>
        </view>
        <view class="habit-info">
          <text class="habit-name">{{item.name}}</text>
          <text class="habit-points">{{item.points}}星星</text>
        </view>
      </view>
      <view class="habit-right">
        <view class="check-btn {{item.todayChecked ? 'checked' : ''}}">
          <text class="check-icon">{{item.todayChecked ? '✓' : '+'}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{habits.length === 0}}">
      <text class="empty-icon">📋</text>
      <text class="empty-text">还没有习惯,快去添加吧</text>
      <button class="btn btn-primary mt-30" bindtap="goToHabitManage">添加习惯</button>
    </view>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tips" wx:if="{{tips}}">
    <text class="tips-icon">💡</text>
    <text class="tips-text">{{tips}}</text>
  </view>
</view>

<!-- 打卡成功弹窗 -->
<view class="modal" wx:if="{{showSuccessModal}}" catchtap="closeSuccessModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="success-animation">
      <text class="success-icon">🎉</text>
    </view>
    <view class="success-title">打卡成功!</view>
    <view class="success-points">
      <text>+{{lastPoints}}星星</text>
      <text class="coins">+{{lastCoins}}金币</text>
    </view>
    <button class="btn btn-primary mt-30" bindtap="closeSuccessModal">确定</button>
  </view>
</view>

  <!-- 升级弹窗 -->
  <view class="modal" wx:if="{{showLevelUpModal}}" catchtap="closeLevelUpModal">
    <view class="modal-content level-up" catchtap="stopPropagation">
      <view class="level-up-animation">
        <text class="level-icon">⭐</text>
      </view>
      <view class="level-up-title">升级啦!</view>
      <view class="level-up-text">
        <text class="old-level">Lv.{{oldLevel}}</text>
        <text class="arrow">→</text>
        <text class="new-level">Lv.{{newLevel}}</text>
      </view>
      <view class="level-up-name">{{newLevelName}}</view>
      <button class="btn btn-primary mt-30" bindtap="closeLevelUpModal">太棒了!</button>
    </view>
  </view>

  <!-- 添加孩子弹窗 -->
  <view class="modal" wx:if="{{showChildModal}}" catchtap="closeChildModal">
    <view class="modal-content child-modal" catchtap="stopPropagation">
      <view class="modal-title">添加孩子</view>

      <view class="form-item">
        <text class="form-label">姓名</text>
        <input
          class="form-input"
          placeholder="请输入孩子姓名"
          value="{{childForm.name}}"
          bindinput="onNameInput"
          maxlength="10"
        />
      </view>

      <view class="avatar-choose">
        <text class="form-label">选择头像</text>
        <view class="avatar-list">
          <view
            class="avatar-option {{item.value === childForm.avatar ? 'active' : ''}}"
            wx:for="{{avatarList}}"
            wx:for-index="index"
            wx:key="index"
            bindtap="selectAvatar"
            data-avatar="{{item.value}}"
            data-type="{{item.type}}">
            <image wx:if="{{item.type === 'image'}}" src="{{item.value}}" class="avatar-img-small"></image>
            <text wx:else class="avatar-emoji">{{item.value}}</text>
          </view>
          
          <!-- 自定义上传按钮 -->
          <view class="avatar-option upload-btn {{childForm.avatarType === 'image' && (childForm.avatar.startsWith('http') || childForm.avatar.startsWith('wxfile')) ? 'active' : ''}}" bindtap="chooseImage">
            <text class="upload-icon">📷</text>
          </view>
        </view>
        
        <!-- 当前选中预览 -->
        <view class="avatar-preview" wx:if="{{childForm.avatarType === 'image'}}">
          <text class="preview-label">当前预览:</text>
          <image src="{{childForm.avatar}}" mode="aspectFill" class="preview-image"></image>
        </view>
      </view>

      <view class="modal-actions">
        <button class="btn btn-outline" bindtap="closeChildModal">取消</button>
        <button class="btn btn-primary" bindtap="saveChild">保存</button>
      </view>
    </view>
  </view>

