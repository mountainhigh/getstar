/* 礼物兑换页面样式 */
.reward-exchange {
  min-height: 100vh;
  background: #f5f5f5;
}

/* 顶部孩子选择器 */
.child-selector {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.child-info {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 20rpx;
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.child-details {
  flex: 1;
}

.child-name {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.child-coins {
  color: #ffd700;
  font-size: 28rpx;
  display: flex;
  align-items: center;
}

.coin-icon {
  margin-right: 8rpx;
}

/* 切换孩子按钮 */
.switch-child-btn {
  width: 120rpx;
  height: 60rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 分类标签 */
.category-tabs {
  display: flex;
  background: #fff;
  padding: 20rpx;
  white-space: nowrap;
  overflow-x: auto;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-tab {
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 32rpx;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.3s;
}

.category-tab.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: bold;
}

/* 礼物列表 */
.reward-list {
  padding: 20rpx;
}

.reward-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.reward-item:active {
  transform: scale(0.98);
}

.reward-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #f6d365 0%, #fda085 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.reward-info {
  flex: 1;
  min-width: 0;
}

.reward-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reward-category {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.reward-cost {
  display: flex;
  align-items: center;
  color: #f5a623;
  font-size: 28rpx;
  font-weight: bold;
}

.cost-icon {
  margin-right: 4rpx;
}

.exchange-btn {
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 32rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.4);
}

/* 兑换确认弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.confirm-content {
  background: #fff;
  width: 85%;
  border-radius: 24rpx;
  padding: 40rpx;
  animation: modalPop 0.3s ease;
}

@keyframes modalPop {
  0% {
    transform: scale(0.8);
    opacity: 0;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.confirm-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  color: #333;
}

.confirm-icon {
  font-size: 120rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.confirm-reward-name {
  font-size: 32rpx;
  text-align: center;
  margin-bottom: 10rpx;
  color: #333;
  font-weight: bold;
}

.confirm-cost {
  font-size: 28rpx;
  text-align: center;
  margin-bottom: 40rpx;
  color: #f5a623;
}

.confirm-buttons {
  display: flex;
  gap: 20rpx;
}

.confirm-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  text-align: center;
}

.cancel-btn {
  background: #f5f5f5;
  color: #666;
}

.ok-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  color: #999;
  font-size: 28rpx;
}
