.leaderboard-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 40rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.filter-bar {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 20rpx;
  padding: 0 30rpx 30rpx;
}

.filter-item {
  padding: 16rpx 32rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  backdrop-filter: blur(10rpx);
  transition: all 0.3s ease;
}

.filter-item.active {
  background: white;
  transform: scale(1.05);
}

.filter-item text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
}

.filter-item.active text {
  color: #667eea;
  font-weight: bold;
}

.leaderboard-list {
  padding: 0 30rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.leaderboard-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
  overflow: hidden;
}

.leaderboard-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 8rpx;
}

.leaderboard-item:nth-child(1)::before {
  background: linear-gradient(180deg, #FFD700, #FFA500);
}

.leaderboard-item:nth-child(2)::before {
  background: linear-gradient(180deg, #C0C0C0, #A0A0A0);
}

.leaderboard-item:nth-child(3)::before {
  background: linear-gradient(180deg, #CD7F32, #A0522D);
}

.rank-badge {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.rank-1 {
  background: linear-gradient(135deg, #FFD700, #FFA500);
  box-shadow: 0 4rpx 12rpx rgba(255, 215, 0, 0.4);
}

.rank-2 {
  background: linear-gradient(135deg, #C0C0C0, #A0A0A0);
  box-shadow: 0 4rpx 12rpx rgba(192, 192, 192, 0.4);
}

.rank-3 {
  background: linear-gradient(135deg, #CD7F32, #A0522D);
  box-shadow: 0 4rpx 12rpx rgba(205, 127, 50, 0.4);
}

.rank-normal {
  background: #f0f0f0;
}

.rank-number {
  font-size: 32rpx;
  font-weight: bold;
  color: white;
}

.rank-normal .rank-number {
  color: #999;
}

.child-info {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid #f0f0f0;
}

.name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stats {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  align-items: flex-end;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stat-value.points {
  font-size: 40rpx;
  color: #FF6B6B;
}

.stat-value.consecutive {
  font-size: 32rpx;
  color: #52C41A;
}

.tips {
  text-align: center;
  padding: 40rpx 30rpx;
}

.tips-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 新增样式 */
.avatar-emoji-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.avatar-emoji {
  font-size: 50rpx;
  line-height: 1;
}
