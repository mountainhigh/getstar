/* 礼物兑换页面样式 - 优化版 */
.exchange-container {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 孩子切换器 - 与首页完全一致的样式 ===== */
.child-switcher {
  margin-bottom: 30rpx;
}

.child-scroll {
  white-space: nowrap;
}

.child-item {
  display: inline-flex;
  align-items: center;
  background: linear-gradient(135deg, #FFE4E1 0%, #FFF0F0 100%);
  border-radius: 50rpx;
  padding: 12rpx 24rpx;
  margin-right: 20rpx;
  border: 3rpx solid rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.child-item.active {
  border-color: #FF6B6B;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
}

.child-item.active .child-name {
  color: #FFFFFF;
}

.child-item.active .child-points {
  color: rgba(255, 255, 255, 0.9);
}

.child-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  margin-right: 16rpx;
  flex-shrink: 0;
  background: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.child-avatar image {
  width: 100%;
  height: 100%;
}

.avatar-emoji {
  font-size: 75rpx;
  font-weight: bold;
  line-height: 1;
}

.child-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.child-name {
  font-size: 15px;
  font-weight: 600;
  color: #2D3436;
}

.child-points {
  font-size: 12px;
  color: #FF6B6B;
  margin-top: 4rpx;
}

/* 顶部导航栏 */
.nav-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
}

.nav-actions {
  display: flex;
  gap: 16rpx;
}

.nav-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

.nav-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.nav-text {
  font-size: 20rpx;
  color: #fff;
  font-weight: 500;
}

/* 分类筛选 */
.category-section {
  padding: 20rpx 0;
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 24rpx;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 20rpx;
  background: #fff;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.category-item.active {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.2);
}

.category-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  transition: all 0.3s ease;
}

.category-icon {
  font-size: 36rpx;
}

.category-name {
  font-size: 24rpx;
  color: #636E72;
  font-weight: 500;
}

.category-item.active .category-name {
  color: #2D3436;
  font-weight: 600;
}

/* 礼物区域 */
.rewards-section {
  padding: 10rpx 24rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.section-count {
  font-size: 26rpx;
  color: #95A5A6;
  background: #f0f0f0;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 礼物网格 */
.rewards-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.reward-card {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.reward-card:active {
  transform: scale(0.96);
}

.reward-card.disabled {
  opacity: 0.6;
}

.reward-header {
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.reward-icon-text {
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.2);
}

.reward-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #44A8B0 100%);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.3);
}

.reward-badge.insufficient {
  background: #E8ECEF;
  box-shadow: none;
}

.reward-badge text {
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
}

.reward-badge.insufficient text {
  color: #95A5A6;
}

.reward-content {
  padding: 20rpx;
}

.reward-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reward-cost {
  display: flex;
  align-items: center;
}

.cost-icon {
  font-size: 28rpx;
  margin-right: 6rpx;
}

.cost-value {
  color: #FF6B6B;
  font-size: 32rpx;
  font-weight: 700;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-animation {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #FFE5E5 0%, #FFF0E5 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.empty-icon {
  font-size: 100rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #95A5A6;
  margin-bottom: 48rpx;
}

.btn-manage {
  display: flex;
  align-items: center;
  padding: 28rpx 56rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.btn-manage::after {
  border: none;
}

.btn-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
  font-weight: bold;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #FFE5E5;
  border-top-color: #FF6B6B;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #95A5A6;
}

/* 底部安全区域 */
.safe-area {
  height: 40rpx;
}

/* 孩子选择弹窗 */
.picker-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.picker-modal.show {
  visibility: visible;
  opacity: 1;
}

.picker-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.picker-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  padding: 30rpx 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.picker-modal.show .picker-content {
  transform: translateY(0);
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx 24rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
}

.picker-close {
  font-size: 40rpx;
  color: #95A5A6;
  padding: 10rpx;
}

.picker-body {
  max-height: 600rpx;
  overflow-y: auto;
  padding: 16rpx 30rpx;
}

.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #f8f9fa;
}

.picker-item.active {
  background: rgba(255, 107, 107, 0.05);
  margin: 0 -30rpx;
  padding: 24rpx 30rpx;
}

.picker-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.picker-avatar text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
}

.picker-info {
  flex: 1;
}

.picker-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.picker-coins {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #FF6B6B;
}

.picker-coin-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

.picker-check {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

/* 兑换确认弹窗 */
.confirm-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.confirm-modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 84%;
  background: #fff;
  border-radius: 36rpx;
  overflow: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.confirm-modal.show .modal-content {
  transform: translate(-50%, -50%) scale(1);
  opacity: 1;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
}

.modal-close {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 10rpx;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.reward-preview {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.preview-icon {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

.preview-icon text {
  color: #fff;
  font-size: 64rpx;
  font-weight: bold;
}

.preview-name {
  font-size: 38rpx;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 12rpx;
}

.preview-category {
  font-size: 28rpx;
  color: #95A5A6;
  background: #f8f9fa;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
}

.exchange-details {
  background: linear-gradient(135deg, #f8f9fa 0%, #fff 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  border: 2rpx solid #f0f0f0;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #E8ECEF;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-row.total {
  margin-top: 8rpx;
  padding-top: 24rpx;
  border-top: 4rpx solid #FF6B6B;
  border-bottom: none;
}

.detail-label {
  display: flex;
  align-items: center;
  font-size: 30rpx;
  color: #636E72;
}

.detail-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.detail-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D3436;
}

.detail-value.cost {
  color: #FF6B6B;
}

.detail-value.remaining {
  color: #4ECDC4;
  font-size: 36rpx;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 30rpx 40rpx;
}

.btn-cancel {
  flex: 1;
  height: 96rpx;
  background: #f0f0f0;
  color: #636E72;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.btn-cancel::after {
  border: none;
}

.btn-confirm {
  flex: 1;
  height: 96rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

/* 新增样式 */
.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.picker-avatar image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
