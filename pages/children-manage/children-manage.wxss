/* pages/children-manage/children-manage.wxss */

/* 孩子管理样式 */
/* 欢迎卡片 - 优化设计 */
.welcome-card {
  text-align: center;
  padding: 100rpx 40rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.welcome-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 107, 107, 0.08) 0%, transparent 70%);
  animation: rotate 20s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.welcome-icon {
  font-size: 140rpx;
  display: block;
  margin-bottom: 40rpx;
  animation: bounce 2s ease-in-out infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.welcome-title {
  font-size: 48rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.welcome-desc {
  font-size: 30rpx;
  color: #636E72;
  line-height: 1.8;
  display: block;
  margin-bottom: 60rpx;
  font-weight: 400;
}

/* 家庭信息 - 优化设计 */
.family-info {
  padding: 36rpx 40rpx;
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(255, 142, 83, 0.05) 100%);
  border-left: 6rpx solid #FF6B6B;
}

.family-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.family-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: 1rpx;
}

.family-members {
  font-size: 26rpx;
  color: #636E72;
  font-weight: 500;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* 孩子列表 - 优化设计 */
.children-section {
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 0 24rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: 1rpx;
}

.btn-add-child {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.btn-add-child:active {
  transform: scale(0.95);
  box-shadow: 0 3rpx 8rpx rgba(255, 107, 107, 0.3);
}

.children-list {
  min-height: 400rpx;
  padding-bottom: 20rpx;
}

/* 孩子卡片 - 优化设计 */
.child-item {
  display: flex;
  align-items: stretch;
  padding: 36rpx;
  margin-bottom: 24rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.child-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #FF6B6B 0%, #FF8E53 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.child-item.active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  box-shadow: 0 12rpx 40rpx rgba(255, 107, 107, 0.35);
  transform: translateY(-4rpx);
}

.child-item.active::before {
  opacity: 1;
}

.child-item.active .child-name,
.child-item.active .child-level,
.child-item.active .stat-value,
.child-item.active .stat-label {
  color: #FFFFFF;
}

.child-avatar {
  position: relative;
  width: 130rpx;
  height: 130rpx;
  border-radius: 65rpx;
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  margin-right: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: 4rpx solid #FFFFFF;
}

.avatar-emoji-display {
  font-size: 65rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.4));
  color: #FFFFFF;
  font-size: 20rpx;
  text-align: center;
  padding: 6rpx 0;
  backdrop-filter: blur(4rpx);
}

.child-info {
  flex: 1;
}

.child-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.child-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: 0.5rpx;
}

.child-level {
  padding: 8rpx 18rpx;
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7AA 100%);
  color: #FFFFFF;
  border-radius: 24rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 8rpx rgba(78, 205, 196, 0.3);
}

.child-stats {
  display: flex;
  align-items: center;
}

.stat-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.stat-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D3436;
  letter-spacing: 0.5rpx;
}

.stat-value.coins {
  font-size: 26rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #95A5A6;
  font-weight: 500;
}

.stat-divider {
  width: 2rpx;
  height: 44rpx;
  background: linear-gradient(180deg, transparent 0%, #E0E0E0 50%, transparent 100%);
  margin: 0 32rpx;
}

.child-actions {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 16rpx;
}

.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 50rpx;
}

.btn-delete-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF5252 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
  transition: all 0.3s ease;
}

.btn-delete-icon:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 6rpx rgba(255, 107, 107, 0.3);
}

.delete-icon {
  font-size: 40rpx;
  line-height: 1;
  color: #FFFFFF;
  font-weight: 300;
}

.btn-switch-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4ECDC4 0%, #45B7AA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(78, 205, 196, 0.3);
  transition: all 0.3s ease;
}

.btn-switch-icon:active {
  transform: scale(0.9);
  box-shadow: 0 2rpx 6rpx rgba(78, 205, 196, 0.3);
}

.switch-icon {
  font-size: 36rpx;
  line-height: 1;
  color: #FFFFFF;
  font-weight: 300;
}

/* 空状态 - 优化设计 */
.empty-state {
  text-align: center;
  padding: 120rpx 40rpx 80rpx;
}

.empty-icon {
  font-size: 140rpx;
  display: block;
  margin-bottom: 36rpx;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.empty-text {
  font-size: 30rpx;
  color: #636E72;
  display: block;
  margin-bottom: 48rpx;
  line-height: 1.8;
}

/* 设置区域 - 优化设计 */
.settings-section {
  padding: 0 30rpx;
  margin-top: 50rpx;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.settings-item:active {
  transform: scale(0.98);
  background: #FAFAFA;
}

.settings-icon {
  font-size: 44rpx;
  margin-right: 24rpx;
  width: 60rpx;
  text-align: center;
}

.settings-text {
  flex: 1;
  font-size: 32rpx;
  color: #2D3436;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.settings-arrow {
  font-size: 36rpx;
  color: #B2BEC3;
  font-weight: 300;
}

/* 弹窗样式 - 优化设计 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.modal-content {
  background: #FFFFFF;
  border-radius: 36rpx;
  padding: 48rpx;
  width: 85%;
  max-width: 600rpx;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(40rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-title {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-align: center;
  margin-bottom: 40rpx;
  letter-spacing: 1rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #2D3436;
  display: block;
  margin-bottom: 18rpx;
  letter-spacing: 0.5rpx;
}

.form-input {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #F8F9FA 0%, #F1F3F5 100%);
  border: 2rpx solid #E9ECEF;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #2D3436;
  transition: all 0.3s ease;
  box-shadow: inset 0 2rpx 4rpx rgba(0, 0, 0, 0.02);
}

.form-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
  box-shadow: 0 0 0 6rpx rgba(255, 107, 107, 0.1);
}

.avatar-choose {
  margin-bottom: 36rpx;
}

.avatar-list {
  display: flex;
  gap: 24rpx;
  flex-wrap: wrap;
  justify-content: center;
  margin-top: 20rpx;
}

.avatar-option {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #F8F9FA 0%, #E9ECEF 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.avatar-option:active {
  transform: scale(0.95);
}

.avatar-option.active {
  border-color: #FF6B6B;
  background: linear-gradient(135deg, #FFF0F0 0%, #FFE8E8 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 107, 107, 0.3);
  transform: scale(1.05);
}

.avatar-emoji {
  font-size: 65rpx;
  line-height: 1;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 48rpx;
}

.modal-actions .btn {
  flex: 1;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* Avatar emoji 样式 */
.avatar-emoji {
  font-size: 60rpx;
  line-height: 1;
}

.avatar-emoji-display {
  font-size: 60rpx;
  line-height: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
