/* 习惯信息卡片 */
.habit-info {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  margin-bottom: 30rpx;
}

.habit-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.habit-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48px;
  margin-right: 24rpx;
  background: rgba(255, 255, 255, 0.3);
}

.habit-details {
  display: flex;
  flex-direction: column;
}

.habit-name {
  font-size: 22px;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.habit-category {
  font-size: 14px;
  opacity: 0.9;
}

.habit-points {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 24rpx;
}

.points-label {
  font-size: 14px;
  opacity: 0.9;
  margin-bottom: 8rpx;
}

.points-value {
  font-size: 36px;
  font-weight: 700;
}

/* 积分修改 */
.points-modify {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 18px;
  font-weight: 700; /* 字重加粗 */
  color: #FF6B6B; /* 改为主题色，更醒目 */
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-title .tips {
  font-size: 13px;
  color: #95A5A6;
  font-weight: 400;
  margin-left: 12rpx;
}

.section-title .optional {
  font-size: 13px;
  color: #95A5A6;
  font-weight: 400;
  margin-left: 12rpx;
}

.points-input-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.points-display-wrapper {
  position: relative;
  flex: 1;
  height: 80rpx;
}

.points-display {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px; /* 字体加大 */
  font-weight: 700;
  color: #FF6B6B;
  pointer-events: none;
  z-index: 1;
}

/* 积分调整按钮 - 使用更具体的选择器确保覆盖全局样式 */
.points-input-wrapper .btn-minus,
.points-input-wrapper .btn-plus {
  width: 80rpx !important;
  height: 80rpx !important;
  border-radius: 50% !important;
  border: 2rpx solid #E8ECEF !important;
  background: #FFFFFF !important;
  font-size: 18px !important;
  font-weight: 600 !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  transition: all 0.3s ease !important;
  padding: 0 !important;
  margin: 0 !important;
  line-height: 1 !important;
  box-sizing: border-box !important;
}

.points-input-wrapper .btn-minus:active,
.points-input-wrapper .btn-plus:active {
  transform: scale(0.95);
}

.points-input-wrapper .btn-minus {
  color: #FF6B6B;
}

.points-input-wrapper .btn-plus {
  color: #4ECDC4;
}

.points-input {
  width: 100%;
  height: 100%;
  background: #F8F9FA;
  border-radius: 12rpx;
  text-align: center;
  font-size: 28px; /* 字体加大 */
  font-weight: 700;
  color: #FF6B6B;
  border: 2rpx solid transparent;
  padding: 0;
  z-index: 2;
}

.points-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.points-hint {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  background: #FFF9E6;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.hint-icon {
  font-size: 16px;
  margin-right: 12rpx;
}

.hint-text {
  font-size: 13px;
  color: #F39C12;
}

/* 照片上传 */
.photo-upload {
  margin-bottom: 30rpx;
}

.section-title .photo-count {
  font-size: 14px;
  color: #4ECDC4;
  font-weight: 600;
  margin-left: auto;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.photo-item {
  aspect-ratio: 1;
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 20px;
  font-weight: 600;
}

.photo-add {
  aspect-ratio: 1;
  border: 2rpx dashed #E8ECEF;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #F8F9FA;
  transition: all 0.3s ease;
}

.photo-add:active {
  background: #F0F1F3;
  border-color: #FF6B6B;
}

.add-icon {
  font-size: 48px;
  color: #95A5A6;
  margin-bottom: 8rpx;
}

.add-text {
  font-size: 13px;
  color: #95A5A6;
}

/* 备注 */
.remark {
  margin-bottom: 30rpx;
}

.remark-input {
  width: 100%;
  min-height: 200rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 15px;
  line-height: 1.6;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.remark-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.remark-count {
  text-align: right;
  font-size: 12px;
  color: #95A5A6;
  margin-top: 12rpx;
}

/* 底部按钮 */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
  z-index: 100;
}

/* 底部占位，防止内容被按钮遮挡 */
.footer-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

.btn-submit {
  width: 100%;
  height: 100rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 50rpx;
  color: #FFFFFF;
  font-size: 18px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.3);
  border: none;
  transition: all 0.3s ease;
}

.btn-submit:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(255, 107, 107, 0.3);
}

.btn-icon {
  font-size: 24px;
  font-weight: 700;
}

/* 额外底部间距 */
.container {
  padding-bottom: 180rpx;
}

/* 底部占位，防止内容被按钮遮挡 */
.footer-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}
