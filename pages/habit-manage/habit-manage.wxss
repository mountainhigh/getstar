/* 页面标题 */
.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  margin-bottom: 30rpx;
}

.page-title {
  font-size: 24px;
  font-weight: 700;
  color: #2D3436;
}

.btn-add {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  border-radius: 32rpx;
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.3);
}

/* 习惯列表 */
.habit-list {
  margin-bottom: 30rpx;
}

.habit-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  transition: all 0.3s ease;
}

.habit-main {
  display: flex;
  align-items: center;
  flex: 1;
}

.habit-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32px;
  margin-right: 24rpx;
  background: rgba(255, 107, 107, 0.1);
}

.habit-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.habit-name {
  font-size: 16px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.habit-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.habit-points {
  font-size: 14px;
  color: #FF6B6B;
  font-weight: 500;
}

.habit-category {
  font-size: 13px;
  color: #95A5A6;
}

.habit-actions {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 20rpx;
}

.btn-action {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #F8F9FA;
  border: 2rpx solid #E8ECEF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 600;
  color: #636E72;
  transition: all 0.3s ease;
  padding: 0;
}

.btn-action:active {
  transform: scale(0.95);
}

.btn-up,
.btn-down {
  color: #4ECDC4;
}

.btn-edit {
  color: #3498DB;
}

.btn-delete {
  color: #FF6B6B;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100px;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 18px;
  color: #2D3436;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 14px;
  color: #95A5A6;
  margin-bottom: 40rpx;
}

/* 统计信息 */
.stats {
  background: linear-gradient(135deg, #4ECDC4 0%, #44A8B0 100%);
  color: #FFFFFF;
}

.stats-title {
  font-size: 16px;
  font-weight: 600;
  margin-bottom: 16rpx;
  opacity: 0.95;
}

.stats-info {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.stats-count {
  font-size: 48px;
  font-weight: 700;
}

.stats-label {
  font-size: 14px;
  opacity: 0.9;
}

/* 编辑弹窗 */
.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  display: block;
  font-size: 15px;
  font-weight: 600;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 15px;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.form-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.points-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.btn-minus,
.btn-plus {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
  background: #F8F9FA;
  border: 2rpx solid #E8ECEF;
  font-size: 20px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-minus {
  color: #FF6B6B;
}

.btn-plus {
  color: #4ECDC4;
}

.points-input {
  flex: 1;
  height: 64rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  color: #FF6B6B;
  border: 2rpx solid transparent;
}

.points-input:focus {
  border-color: #FF6B6B;
  background: #FFFFFF;
}

.switch-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.switch-label {
  font-size: 15px;
  color: #636E72;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 40rpx;
}

.btn-outline {
  flex: 1;
  height: 80rpx;
  border-radius: 50rpx;
  border: 2rpx solid #E8ECEF;
  background: #FFFFFF;
  color: #636E72;
  font-size: 16px;
  font-weight: 600;
}

.btn-primary {
  flex: 1;
  height: 80rpx;
  border-radius: 50rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #FFFFFF;
  font-size: 16px;
  font-weight: 600;
  border: none;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 48rpx;
  width: 85%;
}

.modal-title {
  font-size: 20px;
  font-weight: 700;
  color: #2D3436;
  margin-bottom: 40rpx;
  text-align: center;
}
